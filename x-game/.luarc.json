{
  "$schema": "https://raw.githubusercontent.com/LuaLS/lua-language-server/master/meta/schema.json",
  "runtime": {
    "version": "Lua 5.2"
  },
  "diagnostics": {
    "globals": [
      "rnd", "sfx", "del", "abs", "all", "t", "spr", "mget", "add", "ceil", "flr","pal", "rectfill", "cls"
    ],
    "disable": [
      "lowercase-global"
    ]
  },
  "workspace": {
    "checkThirdParty": false
  }
}
